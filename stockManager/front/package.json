{
  "name": "stock-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Stock Manager",
  "scripts": {
    "analyze": "ANALYZE=1 max build",
    "build": "max build",
    "deploy": "ut run build && ut run gh-pages",
    "dev": "ut run start:dev",
    "gh-pages": "gh-pages -d dist",
    "setup": "max setup",
    "lint": "ut run lint:js && ut run lint:style && ut run lint:prettier",
    "lint-staged": "lint-staged",
    "lint-staged:js": "eslint --ext .js,.jsx,.ts,.tsx ",
    "lint:fix": "eslint --fix --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src && ut run lint:style",
    "lint:js": "eslint --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src",
    "lint:prettier": "prettier --check \"src/**/*\" --end-of-line auto",
    "lint:style": "stylelint --fix \"src/**/*.less\"",
    "precommit": "lint-staged",
    "prettier": "prettier -c --write \"src/**/*\"",
    "start": "max dev",
    "start:dev": "cross-env UMI_ENV=dev MOCK=none PORT=8001 max dev",
    "start:no-mock": "cross-env MOCK=none max dev",
    "start:pre": "cross-env UMI_ENV=pre max dev",
    "start:test": "cross-env UMI_ENV=test MOCK=none max dev",
    "tsc": "tsc --noEmit",
    "clean": "rimraf dist node_modules/.cache",
    "reinstall": "rimraf node_modules package-lock.json && ut install",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,less,md}\"",
    "update-browserslist": "ut x update-browserslist-db@latest"
  },
  "lint-staged": {
    "**/*.less": "stylelint",
    "**/*.{js,jsx,ts,tsx}": "ut run lint-staged:js",
    "**/*.{js,jsx,tsx,ts,less,md,json}": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "Chrome >= 100",
    "Firefox >= 95",
    "Safari >= 15",
    "Edge >= 100"
  ],
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@ant-design/pro-components": "3.1.12-0",
    "@umijs/max": "4.6.69",
    "antd": "^6.5.0",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@umijs/lint": "4.6.69",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "gh-pages": "^6.3.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "rimraf": "^5.0.10",
    "stylelint": "^16.26.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "utoo@1.0.32"
}