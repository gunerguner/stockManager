# Django 配置示例文件
# 复制此文件为 .env 并修改相应配置

# Django SECRET Key
# 生产环境必须生成新的随机值:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your_secret_key_here

# Django 调试模式
# 生产环境必须设置为 false
DJANGO_DEBUG=true

# Redis 连接 URL
# 格式：redis://[host]:[port]/[db]
REDIS_URL=redis://127.0.0.1:6379/1
